# ── LLM backend ──────────────────────────────────────────────
# "ollama"  — easier local setup, run: ollama pull mistral
# "vllm"    — faster, recommended on JarvisLabs GPU
LLM_BACKEND=ollama

# Model name (must match what's available in your backend)
LLM_MODEL=mistral

# vllm server URL (if using vllm backend)
VLLM_URL=http://localhost:8000/v1

# Ollama server URL (if using ollama backend)
OLLAMA_URL=http://localhost:11434

# ── TTS ──────────────────────────────────────────────────────
# Path to downloaded Piper voice model (.onnx file)
# Download: python -m piper --download-dir ./models en_US-lessac-medium
PIPER_MODEL=./models/en_US-lessac-medium.onnx
